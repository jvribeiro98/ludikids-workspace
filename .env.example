# ========== BANCO E REDIS ==========
DATABASE_URL=postgresql://ludikids:ludikids@localhost:5432/ludikids
REDIS_URL=redis://localhost:6379

# ========== JWT ==========
JWT_SECRET=altere-em-producao-jwt-secret-forte
JWT_REFRESH_SECRET=altere-em-producao-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ========== SEED (usuário moderador inicial) ==========
ADMIN_EMAIL=admin@ludikids.com.br
ADMIN_PASSWORD=Admin@123

# ========== TENANT (configuração default) ==========
GEO_FENCE_RADIUS_METERS=200

# ========== BACKUP ==========
BACKUP_DIR=./backups
# BACKUP_RETENTION_COUNT=30

# ========== WEB (frontend) ==========
NEXT_PUBLIC_API_URL=http://localhost:4000
# Produção com domínio (ex.: ludikids.com.br):
# NEXT_PUBLIC_API_URL=https://api.ludikids.com.br
# WEB_ORIGIN=https://ludikids.com.br

# ========== PRODUÇÃO (Docker full + Caddy HTTPS) ==========
# APP_DOMAIN=ludikids.com.br
# CADDY_EMAIL=admin@ludikids.com.br
# WEB_ORIGIN=https://ludikids.com.br
# NEXT_PUBLIC_API_URL=https://api.ludikids.com.br
# RUN_SEED_ON_START=true

# ========== DOCKER COMPOSE ==========
POSTGRES_PASSWORD=ludikids
