# ========== BANCO E REDIS ==========
DATABASE_URL=postgresql://ludikids:ludikids@localhost:5432/ludikids
REDIS_URL=redis://localhost:6379

# ========== JWT ==========
JWT_SECRET=altere-em-producao-jwt-secret-forte
JWT_REFRESH_SECRET=altere-em-producao-refresh-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ========== SEED (usuário moderador inicial) ==========
ADMIN_EMAIL=admin@ludikids.com.br
ADMIN_PASSWORD=Admin@123

# ========== TENANT (configuração default) ==========
GEO_FENCE_RADIUS_METERS=200

# ========== BACKUP ==========
BACKUP_DIR=./backups
# BACKUP_RETENTION_COUNT=30

# ========== WEB (frontend) ==========
# Dev local:
NEXT_PUBLIC_API_URL=http://localhost:4000

# ========== PRODUÇÃO COM DOMÍNIO (Docker full + Caddy HTTPS) ==========
# Substitua SEUDOMINIO pelo seu domínio (ex.: ludikids.com.br).
# APP_DOMAIN=SEUDOMINIO
# CADDY_EMAIL=admin@SEUDOMINIO
# WEB_ORIGIN=https://SEUDOMINIO
# API_URL=https://api.SEUDOMINIO
# NEXT_PUBLIC_API_URL pode ser definido também; a Web usa API_URL em runtime (entrypoint gera runtime-config.js).
# ADMIN_EMAIL=admin@SEUDOMINIO
# ADMIN_PASSWORD=AltereSenhaAdmin123!
# RUN_SEED_ON_START=true

# ========== DOCKER COMPOSE ==========
POSTGRES_PASSWORD=ludikids
